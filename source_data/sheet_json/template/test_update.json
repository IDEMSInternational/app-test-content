{
  "flow_type": "template",
  "flow_name": "test_update",
  "status": "released",
  "rows": [
    {
      "type": "text",
      "value": "# Update"
    },
    {
      "type": "text",
      "value": "## Insert"
    },
    {
      "type": "text",
      "value": "### ID"
    },
    {
      "type": "text_box",
      "name": "recordId",
      "value": "ID 2"
    },
    {
      "type": "text",
      "value": "### Name"
    },
    {
      "type": "text_box",
      "name": "recordName",
      "value": "Name 2"
    },
    {
      "type": "text",
      "value": "### Value"
    },
    {
      "type": "text_box",
      "name": "recordValue",
      "value": "Value 2"
    },
    {
      "type": "text",
      "value": "### Quantity"
    },
    {
      "type": "text_box",
      "name": "recordQuantity",
      "value": 2
    },
    {
      "type": "begin_action",
      "name": "insertAction"
    },
    {
      "type": "update",
      "name": "insertRow",
      "value": "id: '@local.recordId',\nname:'@local.recordName',\nvalue: '@local.recordValue',\nquantity:@local.recordQuantity",
      "parameter_list": "data_list: test_update_data;"
    },
    {
      "type": "end_action"
    },
    {
      "type": "button",
      "name": "insertButton",
      "value": "Add Record",
      "action_list": "click | action: @local.insertAction"
    },
    {
      "type": "button",
      "name": "refreshButton",
      "value": "Refresh",
      "action_list": "click | action: @local.refreshAction"
    },
    {
      "type": "begin_action",
      "name": "refreshAction"
    },
    {
      "type": "query",
      "name": "insertResults",
      "value": "sort: [ {name: 'asc'} ],",
      "parameter_list": "data_list: test_update_data;"
    },
    {
      "type": "end_action"
    },
    {
      "type": "begin_loop",
      "name": "itemLoop",
      "value": "@local.refreshAction.insertResults",
      "parameter_list": "index: id"
    },
    {
      "type": "text",
      "name": "checkInsertedValue",
      "value": "* **ID:** @item.id  \n* **Name:** @item.name  \n* **Value:** @item.value  \n* **Quantity:** @item.quantity  "
    },
    {
      "type": "end_loop"
    }
  ]
}
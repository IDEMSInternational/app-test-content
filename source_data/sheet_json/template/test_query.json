{
  "flow_type": "template",
  "flow_name": "test_query",
  "status": "released",
  "rows": [
    {
      "type": "title",
      "value": "Query"
    },
    {
      "type": "query",
      "name": "queriedData",
      "value": "selector: {active: true},\nsort: [ {name: 'desc'} ],\nlimit: 3",
      "parameter_list": "data_list: test_data;"
    },
    {
      "type": "dropdown",
      "name": "queriedDataDropdown",
      "parameter_list": "options: @local.queriedData;\noptions_key: id;\noptions_value: name;"
    },
    {
      "type": "text",
      "name": "queriedOption",
      "value": "@local.queriedDataDropdown"
    },
    {
      "type": "title",
      "value": "Dynamic Query"
    },
    {
      "type": "query",
      "name": "dynamicQueriedData",
      "value": "selector: {category: '@local.categoryDropdown'},\nsort: [ {name: 'desc'} ],\nlimit: 3",
      "parameter_list": "data_list: test_data"
    },
    {
      "type": "dropdown",
      "name": "dynamicQueriedDataDropdown",
      "parameter_list": "options: @local.dynamicQueriedData;\noptions_key: id;\noptions_value: name;"
    },
    {
      "name": "categoryOptions",
      "value": "key: A | value: A; \nkey: B | value: B;  "
    },
    {
      "type": "dropdown",
      "name": "categoryDropdown",
      "value": "A",
      "parameter_list": "options: @local.categoryOptions;\noptions_key: key;\noptions_value: value;"
    },
    {
      "type": "text",
      "name": "dynamicQueriedOption",
      "value": "@local.dynamicQueriedDataDropdown"
    },
    {
      "type": "title",
      "value": "Dynamic data_list"
    },
    {
      "name": "dataListOptions",
      "value": "key: test_data | value: test_data; \nkey: test_data_alt | value: test_data_alt;  "
    },
    {
      "type": "dropdown",
      "name": "dataListDropdown",
      "value": "test_data",
      "parameter_list": "options: @local.dataListOptions;\noptions_key: key;\noptions_value: value;"
    },
    {
      "type": "query",
      "name": "dynamicListQueriedData",
      "parameter_list": "data_list: @local.dataListDropdown"
    },
    {
      "type": "dropdown",
      "name": "dynamicListQueriedDataDropdown",
      "parameter_list": "options: @local.dynamicListQueriedData;\noptions_key: id;\noptions_value: name;"
    },
    {
      "type": "text",
      "name": "dynamicListQueriedOption",
      "value": "@local.dynamicListQueriedDataDropdown"
    }
  ]
}